generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN @map("SUPER ADMIN")
  ADMIN       @map("ADMIN")
  STAFF       @map("STAFF")
  CUSTOMER    @map("CUSTOMER")
}

enum BookingStatus {
  PENDING   @map("PENDING")
  SCHEDULED @map("SCHEDULED")
  ONGOING   @map("ONGOING")
  COMPLETED @map("COMPLETED")
  CANCELLED @map("CANCELLED")
}

enum PaymentStatus {
  UNPAID         @map("UNPAID")
  PARTIALLY_PAID @map("PARTIALLY PAID")
  PAID           @map("PAID")
}

enum PaymentMethod {
  CASH  @map("CASH")
  GCASH @map("GCASH")
}

enum ServiceCategory {
  EXTERIOR    @map("EXTERIOR")
  INTERIOR    @map("INTERIOR")
  SPECIALIZED @map("SPECIALIZED")
}

model User {
  id String @id @default(cuid())

  email    String @unique
  password String
  fullName String
  phone    String?

  role Role @default(CUSTOMER)

  resetToken       String?
  resetTokenExpiry DateTime?

  active Boolean @default(true)
  archivedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime? @updatedAt

  bookings         Booking[] @relation("CustomerBookings")
  assignedBookings Booking[] @relation("StaffBookings")

  notifications Notification[]

  @@index([role])
  @@index([active])
  @@index([archivedAt])
}

model Service {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  durationMin Int
  category    ServiceCategory
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime?        @updatedAt

  bookingItems BookingItem[]
}

model Booking {
  id Int @id @default(autoincrement())

  customerId      String
  assignedStaffId String?

  addonRequests AddonRequest[]

  status BookingStatus @default(PENDING)

  totalAmount Decimal @default(0.00) @db.Decimal(10, 2)
  amountPaid  Decimal @default(0.00) @db.Decimal(10, 2)

  paymentStatus PaymentStatus @default(UNPAID)

  appointmentStart DateTime
  appointmentEnd   DateTime?

  notes String?

  isLocked Boolean @default(false)

  vehicleType   String?
  plateNumber   String?
  contactNumber String?
  email         String?
  vehicleBrand  String?
  vehicleModel  String?

  paymentMethod PaymentMethod @default(CASH)

  downpaymentRequested Boolean  @default(false)
  downpaymentAmount    Decimal? @db.Decimal(10, 2)

  sameDayReminderSent Boolean @default(false)
  oneHourReminderSent Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  customer      User  @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  assignedStaff User? @relation("StaffBookings", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  items    BookingItem[]
  payments Payment[]

  @@index([customerId])
  @@index([assignedStaffId])
  @@index([status])
  @@index([paymentStatus])
  @@index([downpaymentRequested])
  @@index([appointmentStart])
  @@index([createdAt])
}

model BookingItem {
  id Int @id @default(autoincrement())

  bookingId Int
  serviceId Int

  priceAtBooking       Decimal @db.Decimal(10, 2)
  durationAtBooking    Int
  serviceNameAtBooking String

  quantity Int @default(1)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([bookingId, serviceId])
  @@index([bookingId])
  @@index([serviceId])
}

model Payment {
  id Int @id @default(autoincrement())

  bookingId Int
  amount    Decimal @db.Decimal(10, 2)

  method PaymentMethod @default(CASH)

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
}

model Notification {
  id Int @id @default(autoincrement())

  userId String

  title   String
  message String

  type String @default("GENERAL")

  actionType String?
  actorId    String?
  actorName  String?
  targetId   String?
  targetName String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([actionType])
}

model BusinessSettings {
  id Int @id @default(1)

  openingHour Int @default(8)
  closingHour Int @default(18)

  slotDurationMinutes Int @default(60)

  maxBookingsPerSlot Int @default(3)
  maxServicesPerBooking Int @default(5)

  createdAt DateTime @default(now())
}

model AddonRequest {
  id        Int      @id @default(autoincrement())
  bookingId Int
  services  Json
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  type      String   @default("EMAIL_CHANGE")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([otp])
}

model PendingRegistration {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String
  phone     String?
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([otp])
}
