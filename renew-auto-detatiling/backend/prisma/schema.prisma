generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  CANCELLED
  COMPLETED
  SCHEDULED   // legacy
  PENDING_PAYMENT // legacy
}

enum CancellationStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
}

enum RefundStatus {
  NONE
  PENDING
  PROCESSED
  FORFEITED
}

enum OtpChannel {
  EMAIL
  SMS
}

enum OtpPurpose {
  REGISTRATION
  LOGIN
  PASSWORD_RESET
  EMAIL_CHANGE
  PHONE_CHANGE
}

enum PaymentMethod {
  GCASH
  CASH
  GCASH_POST_SERVICE
}

enum PaymentStatus {
  PENDING
  FOR_VERIFICATION
  PARTIALLY_PAID
  PAID
  REJECTED
  FAILED
  APPROVED    // legacy
  VERIFIED    // legacy
  COMPLETED   // legacy
}

enum ServiceStatus {
  NOT_STARTED
  ONGOING
  COMPLETED
}

enum PaymentType {
  FULL
  DOWNPAYMENT
}

enum PaymentCreatedBy {
  CUSTOMER
  STAFF
}

enum CommunicationSenderRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum AddonRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OcrMatchStatus {
  UNREVIEWED
  MATCH
  MISMATCH
}

enum NotificationChannel {
  WEB
  EMAIL
  SMS
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

// ============================================
// USER MODEL
// ============================================

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  password    String
  fullName    String
  phone       String?

  role           Role     @default(CUSTOMER)
  isActive        Boolean  @default(true)
  emailVerified   Boolean  @default(false)
  archivedAt      DateTime?

  // Notification preferences
  notifyEmail Boolean @default(false)
  notifyWeb   Boolean @default(true)

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings         Booking[]       @relation("CustomerBookings")
  assignedBookings Booking[]    @relation("StaffAssignedBookings")
  notifications   Notification[]
  cancellationRequests CancellationRequest[]
  communicationLogs CommunicationLog[]
  auditLogs        AuditLog[]
  refundsRequested Refund[]       @relation("RefundRequestedBy")
  refundsProcessed Refund[]       @relation("RefundProcessedBy")
  notificationsSent NotificationDispatch[] @relation("NotificationDispatchRecipient")

  // OTP for registration
  otpVerification OtpVerification?

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ============================================
// OTP VERIFICATION MODEL
// ============================================

model OtpVerification {
  id        String    @id @default(cuid())
  userId    String    @unique
  otpHash   String
  channel   OtpChannel @default(EMAIL)
  purpose   OtpPurpose @default(REGISTRATION)
  expiresAt DateTime
  attempts  Int       @default(0)
  resendCount Int     @default(0)
  lockedUntil DateTime?
  lastSentAt DateTime?
  verifiedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// PENDING REGISTRATION MODEL
// ============================================

model PendingRegistration {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String
  phone     String?
  otp       String
  otpAttempts Int    @default(0)
  resendCount Int    @default(0)
  lockedUntil DateTime?
  channel OtpChannel @default(EMAIL)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([expiresAt])
}

// ============================================
// EMAIL VERIFICATION MODEL
// ============================================

model EmailVerification {
  id        Int       @id @default(autoincrement())
  email     String
  otp       String
  type      String    @default("EMAIL_CHANGE")
  attempts  Int       @default(0)
  resendCount Int     @default(0)
  lockedUntil DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@index([expiresAt])
}

// ============================================
// SERVICE MODEL
// ============================================

model Service {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  price       Decimal        @db.Decimal(10, 2)
  durationMin Int
  category    String        @default("EXTERIOR")

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  bookingItems BookingItem[]

  @@index([category])
  @@index([isActive])
}

// ============================================
// BOOKING MODEL
// ============================================

model Booking {
  id         Int  @id @default(autoincrement())
  customerId String

  status BookingStatus @default(SCHEDULED)
  cancellationStatus CancellationStatus @default(NONE)
  refundStatus RefundStatus @default(NONE)
  paymentStatus PaymentStatus @default(PENDING)
  serviceStatus ServiceStatus @default(NOT_STARTED)
  auditLogs    AuditLog[]

  totalAmount    Decimal @db.Decimal(10, 2)
  amountPaid    Decimal @default(0.00) @db.Decimal(10, 2)
  incurredCost  Decimal @default(0.00) @db.Decimal(10, 2)
  refundAmount  Decimal @default(0.00) @db.Decimal(10, 2)

  equipmentDeployed Boolean @default(false)
  equipmentCost    Decimal @default(0.00) @db.Decimal(10, 2)

  paymentMethod PaymentMethod @default(CASH)

  vehicleType   String?
  plateNumber  String?
  contactNumber String?
  vehicleBrand String?
  vehicleModel String?
  notes        String?

  appointmentStart DateTime?
  appointmentEnd   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cancellationReason String?
  cancelledAt       DateTime?
  cancelledBy       String?

  assignedStaffId String?

  downpaymentRequested Boolean @default(false)
  downpaymentAmount Decimal? @db.Decimal(10, 2)
  isDownpaymentRequired Boolean @default(false)
  isLocked Boolean @default(false)
  sameDayReminderSent Boolean @default(false)
  oneHourReminderSent Boolean @default(false)
  startReminderSent Boolean @default(false)
  paymentDeadlineAt DateTime?
  archivedAt DateTime?
  archiveReason String?
  adminOverrideReason String?
  adminOverrideBy String?
  adminOverrideAt DateTime?

  customer       User         @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  assignedStaff User?        @relation("StaffAssignedBookings", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  items                 BookingItem[]
  payments             Payment[]
  cancellationRequests CancellationRequest[]
  communicationLogs   CommunicationLog[]
  addonRequests        AddonRequest[]
  refunds             Refund[]

  @@index([customerId])
  @@index([status])
  @@index([appointmentStart])
  @@index([assignedStaffId])
  @@index([cancellationStatus])
  @@index([paymentDeadlineAt])
  @@index([archivedAt])
}

// ============================================
// BOOKING ITEM MODEL
// ============================================

model BookingItem {
  id        Int  @id @default(autoincrement())
  bookingId Int
  serviceId Int

  serviceNameAtBooking String
  priceAtBooking       Decimal @db.Decimal(10, 2)
  durationAtBooking    Int

  quantity Int @default(1)
  scheduledDateTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([bookingId, serviceId])
  @@index([bookingId])
  @@index([serviceId])
}

// ============================================
// PAYMENT MODEL
// ============================================

model Payment {
  id        Int  @id @default(autoincrement())
  bookingId Int

  amount     Decimal @db.Decimal(10, 2)
  method     PaymentMethod @default(CASH)
  status     PaymentStatus @default(PENDING)
  paymentType PaymentType @default(FULL)
  createdBy  PaymentCreatedBy @default(CUSTOMER)

  // For GCash payments
  proofImage    String?
  proofOriginalName String?
  proofMimeType String?
  proofSizeBytes Int?
  referenceNumber String?
  expectedAmount Decimal? @db.Decimal(10, 2)

  // Verification
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?
  failureReason   String?

  ocrResult PaymentOcrResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
  @@index([method])
  @@index([createdBy])
}

model PaymentOcrResult {
  id        Int  @id @default(autoincrement())
  paymentId Int  @unique

  extractedAmount Decimal? @db.Decimal(10, 2)
  extractedReferenceNumber String?
  extractedDate DateTime?
  rawText String?
  providerName String?
  providerReference String?
  confidence Decimal? @db.Decimal(5, 2)
  matchStatus OcrMatchStatus @default(UNREVIEWED)
  mismatchReason String?
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([matchStatus])
  @@index([createdAt])
}

// ============================================
// CANCELLATION REQUEST MODEL
// ============================================

model CancellationRequest {
  id          Int  @id @default(autoincrement())
  bookingId   Int
  requestedBy String

  reason      String
  status     CancellationStatus @default(REQUESTED)

  // Admin response
  reviewedBy   String?
  reviewedAt  DateTime?
  adminNote   String?

  createdAt DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requester User    @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
  @@index([requestedBy])
}

// ============================================
// COMMUNICATION LOG MODEL
// ============================================

model CommunicationLog {
  id         Int  @id @default(autoincrement())
  bookingId  Int
  senderId   String

  senderRole CommunicationSenderRole
  message    String
  attachment String?

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================
// ADDON REQUEST MODEL
// ============================================

model AddonRequest {
  id        Int     @id @default(autoincrement())
  bookingId Int
  services  Int[]

  status   AddonRequestStatus  @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
}

// ============================================
// NOTIFICATION MODEL
// ============================================

model Notification {
  id     Int    @id @default(autoincrement())
  userId String

  title   String
  message String
  type    String @default("GENERAL")

  relatedId  String?
  actionType String?
  targetId  String?
  targetName String?
  actorId   String?
  actorName String?

  isRead   Boolean @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispatches NotificationDispatch[]

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationDispatch {
  id             String @id @default(cuid())
  notificationId Int?
  recipientUserId String?
  channel        NotificationChannel
  type           String
  status         NotificationDeliveryStatus @default(PENDING)
  destination    String?
  subject        String?
  payload        Json?
  attemptCount   Int @default(0)
  maxAttempts    Int @default(3)
  lastAttemptAt  DateTime?
  nextRetryAt    DateTime?
  deliveredAt    DateTime?
  failureReason  String?
  providerMessageId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  recipientUser User? @relation("NotificationDispatchRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([status, nextRetryAt])
  @@index([channel, status])
  @@index([recipientUserId])
}

// ============================================
// BUSINESS SETTINGS MODEL
// ============================================

model BusinessSettings {
  id Int @id @default(1)

  // Operating Hours
  openingHour Int @default(9)
  closingHour Int @default(18)
  slotDurationMinutes Int @default(60)

  // Booking Limits
  maxBookingsPerSlot    Int @default(3)
  maxServicesPerBooking Int @default(5)

  // Payment Rules
  downpaymentThreshold Decimal @default(5000.00) @db.Decimal(10, 2)
  downpaymentPercentage Decimal @default(0.50) @db.Decimal(5, 2)

  // GCash Payment Info
  gcashNumber String?
  gcashName   String?

  // Cancellation Policy
  cancellationWindowHours Int @default(24)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// AUDIT LOG MODEL
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  bookingId Int?
  
  userId    String?
  action    String
  entityType String
  entityId  String
  performedBy String?
  details   String?

  oldValue  Json?
  newValue  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  performer User? @relation(fields: [userId], references: [id])

  @@index([bookingId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Refund {
  id          Int @id @default(autoincrement())
  bookingId   Int
  requestedBy String?
  processedBy String?

  amount      Decimal @db.Decimal(10, 2)
  status      RefundStatus @default(PENDING)
  reason      String?
  notes       String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requester User?   @relation("RefundRequestedBy", fields: [requestedBy], references: [id], onDelete: SetNull)
  processor User?   @relation("RefundProcessedBy", fields: [processedBy], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([status])
  @@index([processedAt])
}
