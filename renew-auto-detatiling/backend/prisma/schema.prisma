generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
  PENDING_PAYMENT
}

enum CancellationStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
}

enum RefundStatus {
  NONE
  PENDING
  PROCESSED
  FORFEITED
}

enum PaymentMethod {
  GCASH
  CASH
  GCASH_POST_SERVICE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  VERIFIED
  COMPLETED
}

enum PaymentType {
  FULL
  DOWNPAYMENT
}

enum PaymentCreatedBy {
  CUSTOMER
  STAFF
}

enum CommunicationSenderRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum AddonRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// USER MODEL
// ============================================

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  password    String
  fullName    String
  phone       String?

  role           Role     @default(CUSTOMER)
  isActive        Boolean  @default(true)
  emailVerified   Boolean  @default(false)
  archivedAt      DateTime?

  // Notification preferences
  notifyEmail Boolean @default(false)
  notifyWeb   Boolean @default(true)

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings         Booking[]       @relation("CustomerBookings")
  assignedBookings Booking[]    @relation("StaffAssignedBookings")
  notifications   Notification[]
  cancellationRequests CancellationRequest[]
  communicationLogs CommunicationLog[]

  // OTP for registration
  otpVerification OtpVerification?

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ============================================
// OTP VERIFICATION MODEL
// ============================================

model OtpVerification {
  id        String    @id @default(cuid())
  userId    String    @unique
  otpHash   String
  expiresAt DateTime
  attempts  Int       @default(0)
  verifiedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// PENDING REGISTRATION MODEL
// ============================================

model PendingRegistration {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String
  phone     String?
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ============================================
// EMAIL VERIFICATION MODEL
// ============================================

model EmailVerification {
  id        Int       @id @default(autoincrement())
  email     String
  otp       String
  type      String    @default("EMAIL_CHANGE")
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ============================================
// SERVICE MODEL
// ============================================

model Service {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  price       Decimal        @db.Decimal(10, 2)
  durationMin Int
  category    String        @default("EXTERIOR")

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  bookingItems BookingItem[]

  @@index([category])
  @@index([isActive])
}

// ============================================
// BOOKING MODEL
// ============================================

model Booking {
  id         Int  @id @default(autoincrement())
  customerId String

  status BookingStatus @default(PENDING)
  cancellationStatus CancellationStatus @default(NONE)
  refundStatus RefundStatus @default(NONE)
  paymentStatus PaymentStatus @default(PENDING)

  totalAmount    Decimal @db.Decimal(10, 2)
  amountPaid    Decimal @default(0.00) @db.Decimal(10, 2)
  incurredCost  Decimal @default(0.00) @db.Decimal(10, 2)
  refundAmount  Decimal @default(0.00) @db.Decimal(10, 2)

  equipmentDeployed Boolean @default(false)
  equipmentCost    Decimal @default(0.00) @db.Decimal(10, 2)

  paymentMethod PaymentMethod @default(CASH)

  vehicleType   String?
  plateNumber  String?
  contactNumber String?
  vehicleBrand String?
  vehicleModel String?
  notes        String?

  appointmentStart DateTime?
  appointmentEnd   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cancellationReason String?
  cancelledAt       DateTime?
  cancelledBy       String?

  assignedStaffId String?

  downpaymentRequested Boolean @default(false)
  downpaymentAmount Decimal? @db.Decimal(10, 2)
  isDownpaymentRequired Boolean @default(false)
  isLocked Boolean @default(false)
  sameDayReminderSent Boolean @default(false)
  oneHourReminderSent Boolean @default(false)

  customer       User         @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  assignedStaff User?        @relation("StaffAssignedBookings", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  items                 BookingItem[]
  payments             Payment[]
  cancellationRequests CancellationRequest[]
  communicationLogs   CommunicationLog[]
  addonRequests        AddonRequest[]

  @@index([customerId])
  @@index([status])
  @@index([appointmentStart])
  @@index([assignedStaffId])
  @@index([cancellationStatus])
}

// ============================================
// BOOKING ITEM MODEL
// ============================================

model BookingItem {
  id        Int  @id @default(autoincrement())
  bookingId Int
  serviceId Int

  serviceNameAtBooking String
  priceAtBooking       Decimal @db.Decimal(10, 2)
  durationAtBooking    Int

  quantity Int @default(1)
  scheduledDateTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([bookingId, serviceId])
  @@index([bookingId])
  @@index([serviceId])
}

// ============================================
// PAYMENT MODEL
// ============================================

model Payment {
  id        Int  @id @default(autoincrement())
  bookingId Int

  amount     Decimal @db.Decimal(10, 2)
  method     PaymentMethod @default(CASH)
  status     PaymentStatus @default(PENDING)
  paymentType PaymentType @default(FULL)
  createdBy  PaymentCreatedBy @default(CUSTOMER)

  // For GCash payments
  proofImage    String?
  referenceNumber String?

  // Verification
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
  @@index([method])
}

// ============================================
// CANCELLATION REQUEST MODEL
// ============================================

model CancellationRequest {
  id          Int  @id @default(autoincrement())
  bookingId   Int
  requestedBy String

  reason      String
  status     CancellationStatus @default(REQUESTED)

  // Admin response
  reviewedBy   String?
  reviewedAt  DateTime?
  adminNote   String?

  createdAt DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requester User    @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
  @@index([requestedBy])
}

// ============================================
// COMMUNICATION LOG MODEL
// ============================================

model CommunicationLog {
  id         Int  @id @default(autoincrement())
  bookingId  Int
  senderId   String

  senderRole CommunicationSenderRole
  message    String
  attachment String?

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================
// ADDON REQUEST MODEL
// ============================================

model AddonRequest {
  id        Int     @id @default(autoincrement())
  bookingId Int
  services  Int[]

  status   AddonRequestStatus  @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
}

// ============================================
// NOTIFICATION MODEL
// ============================================

model Notification {
  id     Int    @id @default(autoincrement())
  userId String

  title   String
  message String
  type    String @default("GENERAL")

  relatedId  String?
  actionType String?
  targetId  String?
  targetName String?
  actorId   String?
  actorName String?

  isRead   Boolean @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================
// BUSINESS SETTINGS MODEL
// ============================================

model BusinessSettings {
  id Int @id @default(1)

  // Operating Hours
  openingHour Int @default(9)
  closingHour Int @default(18)
  slotDurationMinutes Int @default(60)

  // Booking Limits
  maxBookingsPerSlot    Int @default(3)
  maxServicesPerBooking Int @default(5)

  // Payment Rules
  downpaymentThreshold Decimal @default(5000.00) @db.Decimal(10, 2)
  downpaymentPercentage Decimal @default(0.50) @db.Decimal(5, 2)

  // GCash Payment Info
  gcashNumber String?
  gcashName   String?

  // Cancellation Policy
  cancellationWindowHours Int @default(24)

  // SMTP Configuration
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPassword String?
  smtpFrom     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// AUDIT LOG MODEL
// ============================================

model AuditLog {
  id String @id @default(cuid())

  userId    String?
  action    String
  entityType String
  entityId  String

  oldValue String?
  newValue String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}